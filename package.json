    "@xmldom/xmldom": "^0.9.8",
    "better-sqlite3": "^11.7.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "iconv-lite": "^0.7.2",
    "kordoc": "^2.4.0",
    "pdfjs-dist": "^4.10.38",
    "yauzl": "^3.2.0",
    "zod": "^3.25.76 || ^4.0.0"
